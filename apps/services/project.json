{
  "name": "services",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/services/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/services"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        },
        "staging": {
          "args": ["--node-env=staging"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/services/package.json",
        "{workspaceRoot}/dist/apps/services/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/services/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "services:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "services:build:development"
        },
        "production": {
          "buildTarget": "services:build:production"
        },
        "staging": {
          "buildTarget": "services:build:staging"
        }
      }
    },

    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/{projectName}/Dockerfile -t colauncha/medicpadi-{projectName}:latest ."
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:generate apps/services/src/migrations/ServicesMigration -d apps/services/data-source.ts"
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:run -d apps/services/data-source.ts"
      }
    },
    "migration:run:fake": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:run -d apps/services/data-source.ts --fake"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:revert -d apps/services/data-source.ts"
      }
    },
    "migration:revert:fake": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:revert -d apps/services/data-source.ts --fake"
      }
    }
  },
  "tags": []
}
