{
  "name": "notification",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/notification/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/notification"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        },
        "staging": {
          "args": ["--node-env=staging"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/notification/package.json",
        "{workspaceRoot}/dist/apps/notification/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/notification/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "notification:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "notification:build:development"
        },
        "production": {
          "buildTarget": "notification:build:production"
        },
        "staging": {
          "buildTarget": "notification:build:staging"
        }
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker build -f apps/{projectName}/Dockerfile -t colauncha/medicpadi-{projectName}:latest ."
      }
    },
    "migration:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:generate apps/notification/src/migrations/NotificationMigration -d apps/notification/data-source.ts"
      }
    },
    "migration:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:run -d apps/notification/data-source.ts"
      }
    },
    "migration:run:fake": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:run -d apps/notification/data-source.ts --fake"
      }
    },
    "migration:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:revert -d apps/notification/data-source.ts"
      }
    },
    "migration:revert:fake": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typeorm-ts-node-esm migration:revert -d apps/notification/data-source.ts --fake"
      }
    }
  },
  "tags": [],
  "assets": [
    "apps/notification/src/app/assets",
    "apps/notification/src/app/email/templates"
  ]
}
