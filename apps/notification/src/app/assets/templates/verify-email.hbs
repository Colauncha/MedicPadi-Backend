<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Verify your email address</title>
</head>

<body style="margin:0; padding:0; background:#f4f6f8; font-family:Arial, Helvetica, sans-serif;">

  <table align="center" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" style="background:white; padding:40px; border-radius:8px;">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <img src="cid:logo" alt="MedicPadi Logo" width="80"/>
            </td>
          </tr>

          <!-- Title -->
          <tr>
            <td align="center">
              <h2 style="margin:0; color:#222;">Verify your email address</h2>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding-top:20px; color:#555; font-size:15px; line-height:1.6;">
              Hi {{name}},
              <br /><br />
              Thank you for signing up with MedicPadi! Click the button below to verify your email address:
              <br /><br />
              {{#if verifyUrl}}
              <div style="margin-bottom:16px;">
                <div style="font-size:12px; color:#888; margin-bottom:6px;">Or use this OTP code manually:</div>
                <div style="background:#f0f0f0; padding:10px 20px; display:inline-block; border-radius:4px; font-size:18px; letter-spacing:2px;">
                  {{otp}}
                </div>
              </div>
              {{else}}
              <div style="background:#f0f0f0; padding:10px 20px; display:inline-block; border-radius:4px; font-size:18px; letter-spacing:2px;">
                {{otp}}
              </div>
              {{/if}}
              <div style="margin-top:10px; font-size:12px; color:#b45309;">
                This link and OTP expire in 1 hour. Do not share them with anyone.
              </div>
              <br /><br />
              If you did not create a MedicPadi account, please ignore this email.
              <br /><br />
              <div style="background:#fff7ed; border-left:4px solid #f59e0b; padding:12px 14px; border-radius:4px; font-size:13px; color:#9a3412;">
                <strong>Disclaimer:</strong> If this email accidentally reached your mailbox and you are not the intended recipient, please ignore and delete it.
              </div>
            </td>
          </tr>

          <!-- CTA -->
          <tr>
            <td align="center" style="padding-top:30px;">
              {{#if verifyUrl}}
              <a href="{{verifyUrl}}"
                 style="background:rgb(68, 18, 203); color:white; text-decoration:none; padding:12px 24px; border-radius:6px; font-weight:bold;">
                Verify My Email
              </a>
              {{else}}
              <a href="{{websiteUrl}}"
                 style="background:rgb(68, 18, 203); color:white; text-decoration:none; padding:12px 24px; border-radius:6px; font-weight:bold;">
                Visit Our Website
              </a>
              {{/if}}
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding-top:40px; font-size:12px; color:#888; text-align:center;">
              © {{year}} MedicPadi. All rights reserved.
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
