<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Payment Successful</title>
</head>

<body style="margin:0; padding:0; background:#f4f6f8; font-family:Arial, Helvetica, sans-serif;">

  <table align="center" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" style="background:white; padding:40px; border-radius:8px;">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <img src="cid:logo" alt="MedicPadi Logo" width="80" />
            </td>
          </tr>

          <!-- Title -->
          <tr>
            <td align="center">
              <h2 style="margin:0; color:#222;">Payment Successful</h2>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding-top:20px; color:#555; font-size:15px; line-height:1.6;">
              Hi {{name}},
              <br /><br />
              Your payment has been processed successfully. Here's a summary:
              <br /><br />
              <table width="100%" cellpadding="0" cellspacing="0"
                     style="background:#f0fdf4; border-radius:6px; border-left:4px solid #16a34a;">
                <tr>
                  <td style="padding:16px 20px; font-size:14px; color:#333; line-height:1.8;">
                    <strong>Amount:</strong> {{currency}} {{amount}}<br />
                    <strong>Reference:</strong> <span style="font-family:monospace; letter-spacing:1px;">{{reference}}</span>
                  </td>
                </tr>
              </table>
              <br />
              Please keep your reference number for your records. If you have any questions about
              this payment, contact our support team with the reference above.
              <br /><br />
              <div style="background:#fff7ed; border-left:4px solid #f59e0b; padding:12px 14px; border-radius:4px; font-size:13px; color:#9a3412;">
                <strong>Note:</strong> MedicPadi will never ask for your card details or OTP via email or phone.
              </div>
            </td>
          </tr>

          <!-- CTA -->
          <tr>
            <td align="center" style="padding-top:30px;">
              <a href="{{websiteUrl}}"
                 style="background:rgb(68,18,203); color:white; text-decoration:none; padding:12px 24px; border-radius:6px; font-weight:bold;">
                Go to Dashboard
              </a>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding-top:40px; font-size:12px; color:#888; text-align:center;">
              © {{year}} MedicPadi. All rights reserved.
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
