<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8" />
  <title>Patient has made a payment</title>
</head>

<body style="margin:0; padding:0; background:#f4f6f8; font-family:Arial, Helvetica, sans-serif;">

  <table align="center" width="100%" cellpadding="0" cellspacing="0">
    <tr>
      <td align="center">

        <table width="600" cellpadding="0" cellspacing="0" style="background:white; padding:40px; border-radius:8px;">

          <!-- Logo -->
          <tr>
            <td align="center" style="padding-bottom:20px;">
              <img src="cid:logo" alt="MedicPadi Logo" width="80" />
            </td>
          </tr>

          <!-- Title -->
          <tr>
            <td align="center">
              <h2 style="margin:0; color:#222;">Patient has made a payment</h2>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding-top:20px; color:#555; font-size:15px; line-height:1.6;">
              Hi {{doctorName}},
              <br /><br />
              Great news! A patient has made a payment for their upcoming appointment. The money has been placed in escrow and will be released to you after the appointment is completed.
              <br /><br />
              <table width="100%" cellpadding="0" cellspacing="0"
                     style="background:#f0fdf4; border-radius:6px; border-left:4px solid #16a34a;">
                <tr>
                  <td style="padding:12px 16px; font-size:14px; color:#333;">
                    <strong>Date &amp; Time:</strong> {{appointmentTime}}
                  </td>
                </tr>
              </table>
              <br />
              {{#if meetingLink}}
              You can join the meeting using the button below on the day of the appointment.
              {{else}}
              Your doctor will reach out to you with further details before the appointment.
              {{/if}}
            </td>
          </tr>

          <!-- CTA -->
          {{#if meetingLink}}
          <tr>
            <td align="center" style="padding-top:30px;">
              <a href="{{meetingLink}}"
                 style="background:rgb(68,18,203); color:white; text-decoration:none; padding:12px 24px; border-radius:6px; font-weight:bold;">
                Join Meeting
              </a>
            </td>
          </tr>
          {{/if}}

          <!-- Footer -->
          <tr>
            <td style="padding-top:40px; font-size:12px; color:#888; text-align:center;">
              © {{year}} MedicPadi. All rights reserved.
            </td>
          </tr>

        </table>

      </td>
    </tr>
  </table>

</body>
</html>
